<?xml version="1.0" encoding="UTF-8"?>
<zabbix_export>
  <version>7.0</version>
  <date>2026-03-31T12:00:00Z</date>
  <groups>
    <group>
      <name>Templates/Server hardware</name>
    </group>
  </groups>
  <templates>
    <template>
      <template>Dell OpenManage Enterprise by HTTP agent</template>
      <name>Dell OpenManage Enterprise by HTTP agent</name>
      <description>Enhanced template for Dell OME API monitoring. Features: Auto-discovery, Status/Power/Temperature/Health monitoring, Session alerts, Critical failure detection.</description>
      <groups>
        <group>
          <name>Templates/Server hardware</name>
        </group>
      </groups>
      <macros>
        <macro>
          <macro>{$OME_HOST}</macro>
          <value>https://192.168.1.100</value>
          <description>Dell OME API base URL</description>
        </macro>
        <macro>
          <macro>{$OME_USER}</macro>
          <value>admin</value>
          <description>Username for OME API</description>
        </macro>
        <macro>
          <macro>{$OME_PASSWORD}</macro>
          <value />
          <description>Password for OME API (set manually!)</description>
        </macro>
        <macro>
          <macro>{$OME_UPDATE_INTERVAL}</macro>
          <value>5m</value>
          <description>Discovery interval</description>
        </macro>
        <macro>
          <macro>{$OME_TIMEOUT}</macro>
          <value>30s</value>
          <description>HTTP timeout</description>
        </macro>
        <macro>
          <macro>{$TEMP_WARN_THRESHOLD}</macro>
          <value>65</value>
          <description>Temperature warning threshold (Celsius)</description>
        </macro>
        <macro>
          <macro>{$TEMP_CRIT_THRESHOLD}</macro>
          <value>80</value>
          <description>Temperature critical threshold (Celsius)</description>
        </macro>
      </macros>
      <applications>
        <application>
          <name>Dell OME - Authentication</name>
        </application>
        <application>
          <name>Dell OME - Discovery</name>
        </application>
        <application>
          <name>Dell OME - Status</name>
        </application>
        <application>
          <name>Dell OME - Power</name>
        </application>
        <application>
          <name>Dell OME - Temperature</name>
        </application>
        <application>
          <name>Dell OME - Health</name>
        </application>
        <application>
          <name>Dell OME - Alerts</name>
        </application>
      </applications>
      <items>
        <item>
          <name>OME: Session Authentication</name>
          <type>HTTP_AGENT</type>
          <key>ome.session.auth</key>
          <delay>1m</delay>
          <history>1h</history>
          <trends>0</trends>
          <value_type>4</value_type>
          <applications>Dell OME - Authentication</applications>
          <url>{$OME_HOST}/api/SessionService/Sessions</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>Content-Type</name>
              <value>application/json</value>
            </header>
          </headers>
          <post_data>{"UserName": "{$OME_USER}", "Password": "{$OME_PASSWORD}"}</post_data>
          <retrieve_mode>HEADERS_AND_BODY</retrieve_mode>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.SessionId</parameter>
              </parameters>
            </step>
            <step>
              <type>PROMOTE</type>
              <parameters>
                <parameter>--macro={$OME_SESSION_ID}</parameter>
              </parameters>
            </step>
          </preprocessing>
        </item>
        <item>
          <name>OME: Session Status</name>
          <type>DEPENDENT</type>
          <key>ome.session.status</key>
          <delay>0</delay>
          <history>1h</history>
          <value_type>3</value_type>
          <applications>Dell OME - Authentication</applications>
          <master_item>ome.session.auth</master_item>
          <preprocessing>
            <step>
              <type>STRLEN</type>
              <parameters>
                <parameter />
              </parameters>
            </step>
          </preprocessing>
        </item>
      </items>
      <discovery_rules>
        <discovery_rule>
          <name>Device Discovery</name>
          <type>HTTP_AGENT</type>
          <key>ome.device.discovery</key>
          <delay>{$OME_UPDATE_INTERVAL}</delay>
          <lifetime>7d</lifetime>
          <url>{$OME_HOST}/api/DeviceService/Devices</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>X-Auth-Token</name>
              <value>{$OME_SESSION_ID}</value>
            </header>
          </headers>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.value[*]</parameter>
              </parameters>
            </step>
          </preprocessing>
          <lld_macro_paths>
            <lld_macro_path>
              <path>$..Id</path>
              <name>{#Id}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..DeviceName</path>
              <name>{#DeviceName}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..Model</path>
              <name>{#Model}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..Status</path>
              <name>{#Status}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..PowerState</path>
              <name>{#PowerState}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..DeviceServiceTag</path>
              <name>{#ServiceTag}</name>
            </lld_macro_path>
          </lld_macro_paths>
          <item_prototypes>
            <item_prototype>
              <name>{#DeviceName}: Status</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.status]</key>
              <delay>1m</delay>
              <history>7d</history>
              <value_type>3</value_type>
              <applications>Dell OME - Status</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.Status</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Power State</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.power]</key>
              <delay>1m</delay>
              <history>7d</history>
              <value_type>3</value_type>
              <applications>Dell OME - Power</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.PowerState</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Model</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.model]</key>
              <delay>1m</delay>
              <history>30d</history>
              <value_type>4</value_type>
              <applications>Dell OME - Discovery</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.Model</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Service Tag</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.tag]</key>
              <delay>1m</delay>
              <history>30d</history>
              <value_type>4</value_type>
              <applications>Dell OME - Discovery</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.DeviceServiceTag</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Identifier</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.identifier]</key>
              <delay>1m</delay>
              <history>30d</history>
              <value_type>4</value_type>
              <applications>Dell OME - Discovery</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.Identifier</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Connection State</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.connection]</key>
              <delay>1m</delay>
              <history>7d</history>
              <value_type>3</value_type>
              <applications>Dell OME - Status</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.ConnectionState</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Temperature</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.temperature]</key>
              <delay>2m</delay>
              <history>7d</history>
              <value_type>3</value_type>
              <units>°C</units>
              <applications>Dell OME - Temperature</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})/Temperature</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.Temperature[0].Reading</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
            <item_prototype>
              <name>{#DeviceName}: Health Status</name>
              <type>HTTP_AGENT</type>
              <key>ome.device[{#Id}.health]</key>
              <delay>2m</delay>
              <history>7d</history>
              <value_type>3</value_type>
              <applications>Dell OME - Health</applications>
              <url>{$OME_HOST}/api/DeviceService/Devices({#Id})/SubSystemHealth</url>
              <timeout>{$OME_TIMEOUT}</timeout>
              <headers>
                <header>
                  <name>X-Auth-Token</name>
                  <value>{$OME_SESSION_ID}</value>
                </header>
              </headers>
              <preprocessing>
                <step>
                  <type>JSONPATH</type>
                  <parameters>
                    <parameter>$.HealthState</parameter>
                  </parameters>
                </step>
              </preprocessing>
            </item_prototype>
          </item_prototypes>
          <trigger_prototypes>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.status])=1002</expression>
              <name>Critical Status: {#DeviceName}</name>
              <priority>HIGH</priority>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.status])=1001</expression>
              <name>Warning Status: {#DeviceName}</name>
              <priority>AVERAGE</priority>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.power])=18</expression>
              <name>Power Off: {#DeviceName}</name>
              <priority>AVERAGE</priority>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.connection])=0</expression>
              <name>Not Connected: {#DeviceName}</name>
              <priority>HIGH</priority>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.temperature])&gt;{$TEMP_WARN_THRESHOLD}</expression>
              <name>Temperature Warning: {#DeviceName}</name>
              <priority>AVERAGE</priority>
              <description>Temperature exceeded warning threshold ({$TEMP_WARN_THRESHOLD}°C)</description>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.temperature])&gt;{$TEMP_CRIT_THRESHOLD}</expression>
              <name>Temperature Critical: {#DeviceName}</name>
              <priority>HIGH</priority>
              <description>Temperature exceeded critical threshold ({$TEMP_CRIT_THRESHOLD}°C)</description>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.health])!=1</expression>
              <name>Health Check Failed: {#DeviceName}</name>
              <priority>HIGH</priority>
              <description>Device health status is not Normal</description>
            </trigger_prototype>
            <trigger_prototype>
              <expression>last(ome.device[{#Id}.status])=1002 and last(ome.device[{#Id}.connection])=0</expression>
              <name>CRITICAL FAILURE: {#DeviceName}</name>
              <priority>DISASTER</priority>
              <description>Device is in CRITICAL status AND not connected - possible hardware failure</description>
            </trigger_prototype>
          </trigger_prototypes>
          <graph_prototypes>
            <graph_prototype>
              <name>{#DeviceName}: Status History</name>
              <width>900</width>
              <height>200</height>
              <graph_items>
                <graph_item>
                  <color>199C0D</color>
                  <item>ome.device[{#Id}.status]</item>
                </graph_item>
              </graph_items>
            </graph_prototype>
            <graph_prototype>
              <name>{#DeviceName}: Power State History</name>
              <width>900</width>
              <height>200</height>
              <graph_items>
                <graph_item>
                  <color>F63100</color>
                  <item>ome.device[{#Id}.power]</item>
                </graph_item>
              </graph_items>
            </graph_prototype>
            <graph_prototype>
              <name>{#DeviceName}: Temperature</name>
              <width>900</width>
              <height>200</height>
              <graph_items>
                <graph_item>
                  <color>FF0000</color>
                  <item>ome.device[{#Id}.temperature]</item>
                </graph_item>
              </graph_items>
            </graph_prototype>
          </graph_prototypes>
        </discovery_rule>
      </discovery_rules>
      <dashboards>
        <dashboard>
          <name>Dell OME Monitoring Dashboard</name>
          <private>0</private>
          <pages>
            <page>
              <name>Overview</name>
              <widgets>
                <widget>
                  <type>PROBLEMS</type>
                  <name>Dell OME Problems</name>
                  <x>0</x>
                  <y>0</y>
                  <width>12</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>problemTags</name>
                      <value>Dell</value>
                    </field>
                    <field>
                      <name>showSeverity</name>
                      <value>1</value>
                    </field>
                  </fields>
                </widget>
                <widget>
                  <type>SYSTEM</type>
                  <name>System status</name>
                  <x>12</x>
                  <y>0</y>
                  <width>12</width>
                  <height>7</height>
                </widget>
              </widgets>
            </page>
            <page>
              <name>Devices</name>
              <widgets>
                <widget>
                  <type>GRAPH_PROTOTYPE</type>
                  <name>Status History</name>
                  <x>0</x>
                  <y>0</y>
                  <width>12</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>graph</name>
                      <value>
                        <host>Dell OpenManage Enterprise by HTTP agent</host>
                        <name>{#DeviceName}: Status History</name>
                      </value>
                    </field>
                  </fields>
                </widget>
                <widget>
                  <type>GRAPH_PROTOTYPE</type>
                  <name>Power State</name>
                  <x>12</x>
                  <y>0</y>
                  <width>12</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>graph</name>
                      <value>
                        <host>Dell OpenManage Enterprise by HTTP agent</host>
                        <name>{#DeviceName}: Power State History</name>
                      </value>
                    </field>
                  </fields>
                </widget>
                <widget>
                  <type>GRAPH_PROTOTYPE</type>
                  <name>Temperature</name>
                  <x>0</x>
                  <y>7</y>
                  <width>12</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>graph</name>
                      <value>
                        <host>Dell OpenManage Enterprise by HTTP agent</host>
                        <name>{#DeviceName}: Temperature</name>
                      </value>
                    </field>
                  </fields>
                </widget>
                <widget>
                  <type>GRAPH_PROTOTYPE</type>
                  <name>Health Status</name>
                  <x>12</x>
                  <y>7</y>
                  <width>12</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>graph</name>
                      <value>
                        <host>Dell OpenManage Enterprise by HTTP agent</host>
                        <name>{#DeviceName}: Health</name>
                      </value>
                    </field>
                  </fields>
                </widget>
              </widgets>
            </page>
            <page>
              <name>Alerts</name>
              <widgets>
                <widget>
                  <type>PROBLEMS</type>
                  <name>Critical Alerts</name>
                  <x>0</x>
                  <y>0</y>
                  <width>24</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>severity</name>
                      <value>4,5</value>
                    </field>
                  </fields>
                </widget>
                <widget>
                  <type>PROBLEMS</type>
                  <name>Warning Alerts</name>
                  <x>0</x>
                  <y>7</y>
                  <width>24</width>
                  <height>7</height>
                  <fields>
                    <field>
                      <name>severity</name>
                      <value>2,3</value>
                    </field>
                  </fields>
                </widget>
              </widgets>
            </page>
          </pages>
        </dashboard>
      </dashboards>
    </template>
  </templates>
  <value_maps>
    <value_map>
      <name>Dell OME - Device Status</name>
      <mapping>
        <value>1000</value>
        <label>Normal</label>
      </mapping>
      <mapping>
        <value>1001</value>
        <label>Warning</label>
      </mapping>
      <mapping>
