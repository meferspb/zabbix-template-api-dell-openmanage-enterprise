      <items>
        <item>
          <name>OME: Session Authentication</name>
          <type>HTTP_AGENT</type>
          <key>ome.session.auth</key>
          <delay>1m</delay>
          <history>1h</history>
          <trends>0</trends>
          <value_type>4</value_type>
          <applications>Dell OME - Authentication</applications>
          <url>{$OME_HOST}/api/SessionService/Sessions</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>Content-Type</name>
              <value>application/json</value>
            </header>
          </headers>
          <post_data>{"UserName": "{$OME_USER}", "Password": "{$OME_PASSWORD}"}</post_data>
          <retrieve_mode>HEADERS_AND_BODY</retrieve_mode>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.SessionId</parameter>
              </parameters>
            </step>
            <step>
              <type>PROMOTE</type>
              <parameters>
                <parameter>--macro={$OME_SESSION_ID}</parameter>
              </parameters>
            </step>
          </preprocessing>
        </item>
        <item>
          <name>OME: Session Status</name>
          <type>DEPENDENT</type>
          <key>ome.session.status</key>
          <delay>0</delay>
          <history>1h</history>
          <value_type>3</value_type>
          <applications>Dell OME - Authentication</applications>
          <master_item>ome.session.auth</master_item>
          <preprocessing>
            <step>
              <type>STRLEN</type>
            </step>
          </preprocessing>
        </item>
        <item>
          <name>OME: Device Metrics (Grouped)</name>
          <type>HTTP_AGENT</type>
          <key>ome.metrics.grouped</key>
          <delay>{$METRICS_UPDATE_INTERVAL}</delay>
          <history>7d</history>
          <trends>0</trends>
          <value_type>4</value_type>
          <applications>Dell OME - Utilization</applications>
          <url>{$OME_HOST}/api/MetricService/Metrics</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>Content-Type</name>
              <value>application/json</value>
            </header>
            <header>
              <name>X-Auth-Token</name>
              <value>{$OME_SESSION_ID}</value>
            </header>
          </headers>
          <post_data>{"DeviceIds": [{#Id}], "MetricTypes": [1,2,3,4,9,11,12,14]}</post_data>
          <retrieve_mode>BODY</retrieve_mode>
        </item>
        <item>
          <name>OME: Critical Alerts Count</name>
          <type>HTTP_AGENT</type>
          <key>ome.alerts.critical</key>
          <delay>{$ALERTS_UPDATE_INTERVAL}</delay>
          <history>7d</history>
          <value_type>3</value_type>
          <applications>Dell OME - Alerts</applications>
          <url>{$OME_HOST}/api/AlertService/Alerts?$filter=SeverityType eq 'Critical' and Status eq 'New'</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>X-Auth-Token</name>
              <value>{$OME_SESSION_ID}</value>
            </header>
          </headers>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.@odata.count</parameter>
              </parameters>
            </step>
          </preprocessing>
        </item>
      </items>
      <discovery_rules>
        <discovery_rule>
          <name>Device Discovery</name>
          <type>HTTP_AGENT</type>
          <key>ome.device.discovery</key>
          <delay>{$OME_UPDATE_INTERVAL}</delay>
          <lifetime>7d</lifetime>
          <url>{$OME_HOST}/api/DeviceService/Devices</url>
          <timeout>{$OME_TIMEOUT}</timeout>
          <headers>
            <header>
              <name>X-Auth-Token</name>
              <value>{$OME_SESSION_ID}</value>
            </header>
          </headers>
          <preprocessing>
            <step>
              <type>JSONPATH</type>
              <parameters>
                <parameter>$.value[*]</parameter>
              </parameters>
            </step>
          </preprocessing>
          <lld_macro_paths>
            <lld_macro_path>
              <path>$..Id</path>
              <name>{#Id}</name>
            </lld_macro_path>
            <lld_macro_path>
              <path>$..DeviceName</path>
